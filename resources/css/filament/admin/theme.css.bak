@import '../../../../vendor/filament/filament/resources/css/theme.css';
@source '../../../../app/Filament';
@source '../../../../resources/views/filament';

:root {
    --primary-color: #4f6ba3;
    --secondary-color: #5a7bbf;
}

/* ========================================
   TOPBAR - Professional Design
   ======================================== */
.fi-topbar {
    background-image: url('/images/bgSide.png') !important;
    background-size: cover !important;
    background-position: center !important;
    position: relative !important;
    padding: 1rem 1.5rem !important;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08) !important;
}

.fi-topbar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(79, 107, 163, 0.96), rgba(90, 123, 191, 0.94));
    z-index: 0;
}

.fi-topbar > * {
    position: relative;
    z-index: 1;
}

.fi-topbar a,
.fi-topbar button,
.fi-topbar svg {
    color: white !important;
    stroke: white !important;
    fill: white !important;
}

/* Dropdown Triggers */
.fi-dropdown-trigger,
.fi-user-menu-trigger {
    color: white !important;
    background-color: rgba(255, 255, 255, 0.15) !important;
    border: 1px solid rgba(255, 255, 255, 0.25) !important;
    border-radius: 0.5rem !important;
    padding: 0.5rem 1rem !important;
    font-weight: 500 !important;
    transition: all 0.2s ease !important;
}

.fi-dropdown-trigger:hover,
.fi-user-menu-trigger:hover {
    background-color: rgba(255, 255, 255, 0.25) !important;
    border-color: rgba(255, 255, 255, 0.35) !important;
}

.fi-dropdown-panel {
    background: white !important;
    border-radius: 0.75rem !important;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15) !important;
    border: 1px solid rgba(79, 107, 163, 0.1) !important;
}

.fi-dropdown-list-item {
    transition: all 0.15s ease !important;
}

.fi-dropdown-list-item:hover {
    background-color: rgba(79, 107, 163, 0.08) !important;
}

.fi-dropdown-list-item:hover a,
.fi-dropdown-list-item:hover button {
    color: var(--primary-color) !important;
}

/* Language & Theme Switcher */
.lang-switch {
    display: flex !important;
    gap: 0.5rem !important;
}

.lang-switch a {
    color: white !important;
    background-color: rgba(255, 255, 255, 0.15) !important;
    border: 1px solid rgba(255, 255, 255, 0.25) !important;
    padding: 0.5rem 0.875rem !important;
    border-radius: 0.5rem !important;
    font-weight: 600 !important;
    font-size: 0.875rem !important;
    transition: all 0.2s ease !important;
}

.lang-switch a:hover {
    background-color: rgba(255, 255, 255, 0.25) !important;
    border-color: rgba(255, 255, 255, 0.35) !important;
}

.lang-switch a.active {
    background: white !important;
    color: var(--primary-color) !important;
    border-color: white !important;
}

/* ========================================
   SIDEBAR - Professional Navigation
   ======================================== */
.fi-sidebar {
    background-image: url('/images/bgSide.png') !important;
    background-size: cover !important;
    background-position: center !important;
    position: relative !important;
    box-shadow: 2px 0 10px rgba(0, 0, 0, 0.05) !important;
}

.fi-sidebar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(79, 107, 163, 0.98), rgba(90, 123, 191, 0.96));
    z-index: 0;
}

.fi-sidebar > * {
    position: relative;
    z-index: 1;
}

.fi-sidebar-header {
    padding: 1.5rem !important;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12) !important;
}

.fi-sidebar-nav {
    padding: 1rem !important;
}

.fi-sidebar-item {
    margin-bottom: 0.375rem !important;
}

.fi-sidebar-item-button {
    color: rgba(255, 255, 255, 0.95) !important;
    padding: 0.875rem 1.125rem !important;
    border-radius: 0.625rem !important;
    font-weight: 500 !important;
    transition: all 0.2s ease !important;
}

.fi-sidebar-item-button:hover {
    background-color: rgba(255, 255, 255, 0.12) !important;
    transform: translateX(4px) !important;
}

.fi-sidebar-item.fi-active .fi-sidebar-item-button {
    background: rgba(255, 255, 255, 0.2) !important;
    border-left: 4px solid white !important;
    padding-left: calc(1.125rem - 4px) !important;
    font-weight: 600 !important;
    box-shadow: 0 2px 8px rgba(255, 255, 255, 0.15) !important;
}

.fi-sidebar-item-icon {
    color: white !important;
    width: 1.25rem !important;
    height: 1.25rem !important;
}

.fi-sidebar-item-label {
    color: white !important;
    font-size: 0.9375rem !important;
}

.fi-sidebar-group-label {
    color: rgba(255, 255, 255, 0.65) !important;
    font-size: 0.75rem !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.08em !important;
    padding: 1rem 1.125rem 0.5rem !important;
}

/* ========================================
   MAIN CONTENT - Professional Dashboard
   ======================================== */
.fi-main {
    background: #f5f7fa !important;
    padding: 2rem !important;
    min-height: 100vh !important;
}

/* Page Header */
.fi-header {
    margin-bottom: 2rem !important;
    padding-bottom: 1rem !important;
    border-bottom: 2px solid rgba(79, 107, 163, 0.1) !important;
}

.fi-header-heading {
    color: var(--primary-color) !important;
    font-weight: 700 !important;
    font-size: 2rem !important;
    margin-bottom: 0.25rem !important;
}

.fi-header-subheading {
    color: #64748b !important;
    font-size: 0.9375rem !important;
}

/* Dashboard Stats Cards */
.fi-section {
    background: white !important;
    border-radius: 1rem !important;
    border: 1px solid #e5e9f0 !important;
    box-shadow: 0 2px 8px rgba(79, 107, 163, 0.06) !important;
    margin-bottom: 1.5rem !important;
    transition: all 0.2s ease !important;
}

.fi-section:hover {
    box-shadow: 0 4px 16px rgba(79, 107, 163, 0.12) !important;
    transform: translateY(-2px) !important;
}

.fi-section-header {
    padding: 1.5rem !important;
    border-bottom: 1px solid #e5e9f0 !important;
    background: linear-gradient(135deg, rgba(79, 107, 163, 0.02), rgba(90, 123, 191, 0.02)) !important;
}

.fi-section-header-heading {
    color: var(--primary-color) !important;
    font-weight: 700 !important;
    font-size: 1.25rem !important;
}

.fi-section-content {
    padding: 1.5rem !important;
}

/* Widget Stats */
.fi-wi-stats-overview-card {
    background: white !important;
    border-radius: 1rem !important;
    border: 1px solid #e5e9f0 !important;
    padding: 1.75rem !important;
    box-shadow: 0 2px 8px rgba(79, 107, 163, 0.06) !important;
    transition: all 0.2s ease !important;
}

.fi-wi-stats-overview-card:hover {
    box-shadow: 0 6px 20px rgba(79, 107, 163, 0.12) !important;
    transform: translateY(-3px) !important;
    border-color: rgba(79, 107, 163, 0.2) !important;
}

.fi-wi-stats-overview-stat-value {
    color: var(--primary-color) !important;
    font-size: 2.5rem !important;
    font-weight: 800 !important;
    line-height: 1 !important;
    margin-bottom: 0.5rem !important;
}

.fi-wi-stats-overview-stat-label {
    color: #64748b !important;
    font-size: 0.9375rem !important;
    font-weight: 600 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
}

.fi-wi-stats-overview-stat-description {
    color: #94a3b8 !important;
    font-size: 0.875rem !important;
    margin-top: 0.5rem !important;
}

.fi-wi-stats-overview-stat-icon {
    color: var(--primary-color) !important;
    opacity: 0.2 !important;
    font-size: 3rem !important;
}

/* Tables */
.fi-ta {
    border-radius: 1rem !important;
    overflow: hidden !important;
    border: 1px solid #e5e9f0 !important;
    box-shadow: 0 2px 8px rgba(79, 107, 163, 0.06) !important;
}

.fi-ta-header {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)) !important;
}

.fi-ta-header-cell {
    color: white !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    font-size: 0.8125rem !important;
    letter-spacing: 0.05em !important;
    padding: 1.125rem 1.5rem !important;
}

.fi-ta-row {
    transition: all 0.15s ease !important;
    border-bottom: 1px solid #f1f5f9 !important;
}

.fi-ta-row:hover {
    background-color: rgba(79, 107, 163, 0.04) !important;
}

.fi-ta-cell {
    padding: 1.125rem 1.5rem !important;
    color: #475569 !important;
}

/* Buttons */
.fi-btn-primary {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)) !important;
    color: white !important;
    border: none !important;
    font-weight: 600 !important;
    padding: 0.75rem 1.5rem !important;
    border-radius: 0.625rem !important;
    box-shadow: 0 4px 12px rgba(79, 107, 163, 0.25) !important;
    transition: all 0.2s ease !important;
}

.fi-btn-primary:hover {
    box-shadow: 0 6px 20px rgba(79, 107, 163, 0.35) !important;
    transform: translateY(-2px) !important;
}

.fi-btn {
    border-radius: 0.625rem !important;
    font-weight: 500 !important;
    transition: all 0.2s ease !important;
}

/* Forms */
.fi-input,
.fi-select,
.fi-textarea {
    border: 1.5px solid #e5e9f0 !important;
    border-radius: 0.625rem !important;
    transition: all 0.2s ease !important;
}

.fi-input:focus,
.fi-select:focus,
.fi-textarea:focus {
    border-color: var(--primary-color) !important;
    box-shadow: 0 0 0 4px rgba(79, 107, 163, 0.1) !important;
    outline: none !important;
}

/* Badges */
.fi-badge {
    border-radius: 0.5rem !important;
    padding: 0.375rem 0.875rem !important;
    font-size: 0.8125rem !important;
    font-weight: 700 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.05em !important;
}

/* Modal */
.fi-modal {
    border-radius: 1rem !important;
    overflow: hidden !important;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2) !important;
}

.fi-modal-header {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color)) !important;
    color: white !important;
    padding: 2rem !important;
}

.fi-modal-heading {
    color: white !important;
    font-weight: 700 !important;
    font-size: 1.5rem !important;
}

/* ========================================
   RESPONSIVE
   ======================================== */
@media (max-width: 768px) {
    .fi-main {
        padding: 1rem !important;
    }
    
    .fi-header-heading {
        font-size: 1.5rem !important;
    }
    
    .fi-wi-stats-overview-stat-value {
        font-size: 2rem !important;
    }
}

/* Scrollbar */
.fi-sidebar::-webkit-scrollbar {
    width: 6px;
}

.fi-sidebar::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
}

.fi-sidebar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 3px;
}

.fi-sidebar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.3);
}
